# Cloudflare Workers static assets reads this file from the asset directory.
# Do NOT put comments inside a rule block — an indented # line makes Cloudflare
# silently drop the whole block. Comments go here, at column zero, between blocks.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin

# Astro content-addresses these filenames, so the bytes behind a given URL can
# never change and `immutable` is the truth rather than a hope.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# The fonts are hand-vendored into public/ and keep stable filenames, so this
# path is NOT content-addressed. `immutable` would promise something untrue:
# re-subsetting a face to pick up a glyph the site does not yet carry changes
# the bytes but not the URL, and every returning visitor would keep the old
# file. A month, revalidating in the background, costs almost nothing and stays
# recoverable. It also caps how long a stray 404 under this path can stick.

/fonts/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400
