---
import { existsSync } from 'node:fs';
import Base from '../layouts/Base.astro';
import Plate from '../components/Plate.astro';
import PubRow from '../components/PubRow.astro';
import { site } from '../data/site.js';
import { projects } from '../data/projects.js';
import { selected, counts } from '../data/publications.js';
import { news } from '../data/news.js';

const hasPortrait = existsSync(new URL('../../public/portrait.jpg', import.meta.url));
const recentNews = news.slice(0, 5);
const awardsLead = site.awardsSelected[0];
const awardsRest = site.awardsSelected.slice(1);

const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const fmt = (d) => { const [y, m] = d.split('-'); return `${MONTHS[+m - 1]} ${y}`; };
const PANEL_SHORT = {
  'Computational Neuroscience': 'Comp. neuro',
  'Artificial Intelligence': 'AI',
  'AI for Science': 'AI for science',
  'Philosophy of Perception': 'Philosophy',
};
---

<Base description={`Draco (Yunlong) Xu — PhD candidate in the Committee on Computational Neuroscience at the University of Chicago, working with Brent Doiron on the ${site.identity}.`}>

  <!-- 1 · IDENTITY -->
  <section class="bay id-block">
    <div class="rail">
      <ul class="statuslist">{site.status.map((s) => <li>{s}</li>)}</ul>
    </div>
    <div class="main">
      <h1 class="wordmark">{site.name}</h1>
      <p class="position">
        PhD Candidate, {site.program}, {site.institution}.
        Advised by <a href={site.advisor.href}>{site.advisor.name}</a>.
      </p>
      <p class="identity">I study the {site.identity}.</p>
      <p class="linkrow">
        {site.links.map((l, i) => (<>{i > 0 && <span class="sl">/</span>}<a href={l.href} rel="me noopener">{l.label}</a></>))}
        <span class="sl">/</span><span class="seal-inline" aria-hidden="true"></span><a href="/cv.pdf">CV (PDF, {site.cvUpdated})</a>
      </p>
      <p class="mail">{site.contact.email}</p>
      <div class="prose bio">
        {site.intro.map((para) => <p set:html={para}></p>)}
      </div>
    </div>
    <div class="note">
      {hasPortrait && (
        <img class="portrait" src="/portrait.jpg" alt="Draco (Yunlong) Xu" width="176" height="220" loading="eager" />
      )}
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 2 · RESEARCH — framing paragraph, then the three panels, then philosophy note -->
  <section class="bay">
    <div class="main"><p class="lbl">Research</p></div>
  </section>
  <section class="bay">
    <div class="main prose"><p>{site.framing}</p></div>
  </section>
  <section class="bay">
    <div class="wide">
      <div class="triad">
        {site.approaches.map((a) => (<div><h3>{a.name}</h3><p>{a.line}</p></div>))}
      </div>
      <p class="undernote">{site.approachesNote}</p>
      <p class="linkrow" style="margin-top:var(--ma-3)"><a href="/research/">Full research statement →</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 3 · PROJECTS -->
  <section class="bay">
    <div class="main">
      <p class="lbl">Ongoing and recent projects</p>
      <p class="subhead">Six lines of work, running in parallel. The order is a reading order, not a ranking.</p>
    </div>
  </section>
  <section class="bay">
    <div class="wide">
      {projects.map((p) => (
        <a class="row prow" href={`/projects/#${p.id}`}>
          <Plate kind={p.plate} seed={p.title} alt={`Figure plate — ${p.short}`} />
          <div>
            <p class="row-t">{p.short}</p>
            <p class="row-a">{p.blurb}</p>
          </div>
          <div class="row-m">{PANEL_SHORT[p.panels[0]] || p.panels[0]}</div>
        </a>
      ))}
      <p class="linkrow" style="margin-top:var(--ma-3)"><a href="/projects/">All six in detail →</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 4 · SELECTED PUBLICATIONS -->
  <section class="bay">
    <div class="main">
      <p class="lbl">Selected publications</p>
      <p class="subhead">Journal, conference, and preprint work — a selection below.</p>
    </div>
  </section>
  <section class="bay">
    <div class="wide">
      {selected.map((p) => <PubRow item={p} />)}
      <p class="linkrow" style="margin-top:var(--ma-3)"><a href="/publications/">All publications →</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 5 · AWARDS & FUNDING — repositioned above Education, led by the void band -->
  <section class="bay">
    <div class="main">
      <p class="lbl">Awards &amp; funding</p>
      <p class="subhead">Fellowships, research grants, and honors that fund the work. Selected —</p>
    </div>
  </section>
  <div class="bay">
    <div class="monolith">
      <div class="inner award-lead">
        <span class="award-headline">{awardsLead.what}</span>
        <span class="award-org">{awardsLead.who} · {awardsLead.when}</span>
      </div>
    </div>
  </div>
  <section class="bay">
    <div class="wide">
      {awardsRest.map((a) => (
        <div class="dated">
          <div class="dated-when">{a.when}</div>
          <div><p class="dated-what">{a.what}</p></div>
          <div class="dated-where">{a.who}</div>
        </div>
      ))}
      <p class="linkrow" style="margin-top:var(--ma-3)"><a href="/cv.pdf">Full list in the CV →</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 6 · NEWS -->
  <section class="bay">
    <div class="main"><p class="lbl">News</p></div>
  </section>
  <section class="bay">
    <div class="wide">
      {recentNews.map((n) => (
        <div class="dated newsrow">
          <div class="dated-when">{fmt(n.date)}</div>
          <div>
            <p class="dated-what">{n.body}</p>
            {n.links && (
              <p class="linkrow">
                {n.links.map((l, i) => (<>{i > 0 && <span class="sl">·</span>}<a href={l.href}>{l.label}</a></>))}
              </p>
            )}
          </div>
        </div>
      ))}
      <p class="linkrow" style="margin-top:var(--ma-3)"><a href="/news/">All news →</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 7 · EDUCATION -->
  <section class="bay">
    <div class="main"><p class="lbl">Education</p></div>
  </section>
  <section class="bay">
    <div class="wide">
      {site.education.map((e) => (
        <div class="dated">
          <div class="dated-when">{e.years}</div>
          <div><p class="dated-what">{e.degree}</p><p class="dated-detail">{e.detail}</p></div>
          <div class="dated-where">{e.where}</div>
        </div>
      ))}
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 8 · COLLABORATORS -->
  <section class="bay">
    <div class="main"><p class="lbl">Collaborators</p></div>
  </section>
  <section class="bay">
    <div class="wide">
      <ul class="names">
        {site.collaborators.map((c) => (
          <li>
            {c.href ? <a href={c.href}>{c.name}</a> : <span>{c.name}</span>}
            <span class="inst">{c.where}{c.role ? ' · ' + c.role : ''}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 9 · BEYOND ACADEMIC -->
  <section class="bay">
    <div class="main">
      <p class="lbl">Beyond academic</p>
      <p class="dated-what" style="max-width:64ch">
        Trained as a stage actor with the Fudan Drama Troupe, and currently with the
        Windmill Chinese Drama Club in Chicago.
      </p>
      <p class="motto">{site.motto}</p>
      <p class="linkrow"><a href="/stage/">Stage →</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 10 · CONTACT -->
  <section class="bay">
    <div class="main">
      <p class="lbl">Contact</p>
      <p class="dated-what">{site.contact.email}</p>
      <p class="dated-what" style="color:var(--sea)">{site.closing}</p>
    </div>
    <div class="note">
      <p class="notesm">{site.contact.address.map((l) => <>{l}<br /></>)}</p>
    </div>
  </section>
</Base>

<style>
  .id-block { padding-top: var(--ma-4); }
  .statuslist { display: flex; flex-direction: column; gap: var(--ma-1); }
  .statuslist li {
    font-family: var(--mono); font-size: 11px; letter-spacing: .08em;
    text-transform: uppercase; color: var(--sea); line-height: 1.55;
  }
  .position { font-size: 17.5px; line-height: 1.5; margin: var(--ma-2) 0; max-width: 60ch; }
  .identity { font-style: italic; font-size: 19px; line-height: 1.45; color: var(--sea); margin: 0 0 var(--ma-3); max-width: 60ch; }
  .mail { font-family: var(--mono); font-size: 12px; color: var(--contour); margin: var(--ma-1) 0 var(--ma-3); }
  .bio { margin: 0; }
  .bio p { margin: 0 0 var(--ma-2); }
  .bio p:last-child { margin-bottom: 0; }
  .seal-inline { display: inline-block; width: 7px; height: 7px; background: var(--oxide); margin-right: 6px; vertical-align: 1px; }

  .portrait { width: 100%; max-width: 11rem; height: auto; border: 1px solid var(--kei); filter: grayscale(.12); }

  .notesm { font-size: 13px; line-height: 1.55; color: var(--sea); margin: 0; }
  .subhead {
    font-family: var(--mono); font-size: 11px; letter-spacing: .1em;
    text-transform: uppercase; color: var(--sea); margin: calc(var(--ma-1) * -1) 0 0;
  }
  .undernote {
    font-size: 14px; line-height: 1.55; color: var(--sea);
    max-width: 64ch; margin: var(--ma-4) 0 0; padding-left: var(--ma-3);
    border-left: 1px solid var(--kei);
  }
  .prow { background-image: none; color: inherit; }
  .prow:hover { background-size: 0 1px; }
  .newsrow { grid-template-columns: 8.5rem minmax(0, 1fr); }
  .motto { font-style: normal; font-family: var(--mono); font-size: 11.5px; letter-spacing: .12em; text-transform: uppercase; color: var(--sea); margin: var(--ma-2) 0; }

  .award-lead { font-style: normal; display: flex; flex-direction: column; gap: var(--ma-2); }
  .award-headline { font-size: clamp(1.4rem, 2.6vw, 1.9rem); line-height: 1.2; }
  .award-org { font-family: var(--mono); font-size: 11.5px; letter-spacing: .1em; text-transform: uppercase; opacity: .8; }

  @media (max-width: 760px) { .newsrow { grid-template-columns: 7rem minmax(0, 1fr); } }
</style>
