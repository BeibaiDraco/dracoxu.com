---
import { existsSync } from 'node:fs';
import Base from '../layouts/Base.astro';
import Plate from '../components/Plate.astro';
import PubRow from '../components/PubRow.astro';
import { site } from '../data/site.js';
import { projects } from '../data/projects.js';
import { selected, counts } from '../data/publications.js';
import { news } from '../data/news.js';

const hasPortrait = existsSync(new URL('../../public/portrait.jpg', import.meta.url));
const recentNews = news.slice(0, 5);
const awardsLead = site.awardsSelected[0];
const awardsRest = site.awardsSelected.slice(1);

const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const fmt = (d) => { const [y, m] = d.split('-'); return `${MONTHS[+m - 1]} ${y}`; };
const PANEL_SHORT = {
  'Computational Neuroscience': 'Comp. neuro',
  'Science of Intelligence': 'Intelligence',
  'AI for Science': 'AI for Science',
};

/* Structured data, so a search engine can tie this page to the same person on
   Scholar and GitHub rather than guessing from a common surname. */
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Draco (Yunlong) Xu',
  alternateName: 'Yunlong Xu',
  url: 'https://dracoxu.com/',
  image: 'https://dracoxu.com/portrait.jpg',
  email: `mailto:${site.contact.email}`,
  jobTitle: 'PhD Candidate',
  affiliation: { '@type': 'CollegeOrUniversity', name: 'University of Chicago', url: 'https://www.uchicago.edu/' },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'University of Rochester' },
    { '@type': 'CollegeOrUniversity', name: 'Fudan University' },
  ],
  knowsAbout: ['Computational Neuroscience', 'Theoretical Neuroscience', 'Science of Intelligence', 'AI for Science'],
  sameAs: site.links.filter((l) => l.label !== 'Email').map((l) => l.href),
};
---

<Base description="Draco (Yunlong) Xu — PhD candidate in computational neuroscience at the University of Chicago, in Brent Doiron’s lab. Computation, perception, experience.">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(personLd)}></script>

  <!-- 1 · IDENTITY — portrait on the left, status on the right -->
  <section class="bay id-block">
    <div class="rail">
      {hasPortrait && (
        <img class="portrait" src="/portrait.jpg" alt="Draco (Yunlong) Xu" width="152" height="199" loading="eager" />
      )}
    </div>
    <div class="main">
      <h1 class="wordmark">{site.name}</h1>
      <p class="position">
        PhD Candidate, {site.program}, {site.institution}.
        Advised by <a href={site.advisor.href}>{site.advisor.name}</a>.
      </p>
      <p class="identity">I study the {site.identity}.</p>
      <p class="linkrow">
        {site.links.map((l, i) => (<>{i > 0 && <span class="sl">/</span>}<a href={l.href} rel="me noopener">{l.label}</a></>))}<span class="sl">/</span><span class="seal-inline" aria-hidden="true"></span><a href="/cv.pdf">CV (PDF, {site.cvUpdated})</a>
      </p>
      <p class="mail"><a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></p>
      <div class="prose bio">
        {site.intro.map((para) => <p set:html={para}></p>)}
      </div>
    </div>
    <div class="note">
      <ul class="statuslist">{site.status.map((s) => <li>{s}</li>)}</ul>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 2 · RESEARCH — framing paragraph, then the three panels, then philosophy note -->
  <section class="bay">
    <div class="wide"><h2 class="lbl">Research</h2></div>
  </section>
  <section class="bay">
    <div class="wide prose lead"><p>{site.framing}</p></div>
  </section>
  <section class="bay">
    <div class="approaches">
      <div class="triad">
        {site.approaches.map((a) => (<div><h3>{a.name}</h3><p>{a.line}</p></div>))}
      </div>
      <p class="undernote">{site.approachesNote}</p>
      <p class="linkrow" style="margin-top:var(--ma-3)"><a href="/research/">Full research statement →</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 3 · PROJECTS -->
  <section class="bay">
    <div class="wide">
      <h2 class="lbl">Ongoing and recent projects</h2>
      <p class="subhead">Six lines of work, running in parallel. The order is a reading order, not a ranking.</p>
    </div>
  </section>
  <section class="bay">
    <div class="wide">
      {projects.map((p) => (
        <a class="row prow" href={`/projects/#${p.id}`}>
          <Plate kind={p.plate} seed={p.title} decorative={true} />
          <div>
            <p class="row-t">{p.short}</p>
            <p class="row-a">{p.blurb}</p>
          </div>
          <div class="row-m">{p.panels.map((t, i) => (<>{i > 0 && <br />}<span class="tagnw">{PANEL_SHORT[t] || t}</span></>))}</div>
        </a>
      ))}
      <p class="linkrow" style="margin-top:var(--ma-3)"><a href="/projects/">All six in detail →</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 4 · SELECTED PUBLICATIONS -->
  <section class="bay">
    <div class="wide">
      <h2 class="lbl">Selected publications</h2>
      <p class="subhead">Journal, conference, and preprint work — a selection below.</p>
    </div>
  </section>
  <section class="bay">
    <div class="wide">
      {selected.map((p) => <PubRow item={p} />)}
      <p class="linkrow" style="margin-top:var(--ma-3)"><a href="/publications/">All publications →</a></p>
      <p class="legend" style="margin-top:var(--ma-2)">* denotes equal contribution.</p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 5 · AWARDS & FUNDING — repositioned above Education, led by the void band -->
  <section class="bay">
    <div class="wide">
      <h2 class="lbl">Selected awards &amp; funding</h2>
      <p class="subhead">Grants, fellowships, and honors.</p>
    </div>
  </section>
  <section class="bay">
    <div class="wide">
      <div class="dated award-lead-row">
        <div class="dated-when">{awardsLead.when}</div>
        <div>
          <p class="award-headline">
            {awardsLead.href ? <a href={awardsLead.href}>{awardsLead.what}</a> : awardsLead.what}
          </p>
        </div>
        <div class="dated-where">{awardsLead.who}</div>
      </div>
      {awardsRest.map((a) => (
        <div class="dated">
          <div class="dated-when">{a.when}</div>
          <div><p class="dated-what">{a.href ? <a href={a.href}>{a.what}</a> : a.what}</p></div>
          <div class="dated-where">{a.who}</div>
        </div>
      ))}
      <p class="linkrow" style="margin-top:var(--ma-3)"><a href="/cv.pdf">Full list in the CV →</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 6 · NEWS -->
  <section class="bay">
    <div class="wide"><h2 class="lbl">News</h2></div>
  </section>
  <section class="bay">
    <div class="wide">
      {recentNews.map((n) => (
        <div class="dated newsrow">
          <div class="dated-when">{fmt(n.date)}</div>
          <div>
            <p class="dated-what">{n.body}</p>
            {n.links && (
              <p class="linkrow">
                {n.links.map((l, i) => (<>{i > 0 && <span class="sl">·</span>}<a href={l.href}>{l.label}</a></>))}
              </p>
            )}
          </div>
        </div>
      ))}
      <p class="linkrow" style="margin-top:var(--ma-3)"><a href="/news/">All news →</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 7 · EDUCATION -->
  <section class="bay">
    <div class="wide"><h2 class="lbl">Education</h2></div>
  </section>
  <section class="bay">
    <div class="wide">
      {site.education.map((e) => (
        <div class="dated">
          <div class="dated-when">{e.years}</div>
          <div><p class="dated-what">{e.degree}</p><p class="dated-detail">{e.detail}</p></div>
          <div class="dated-where">{e.where}</div>
        </div>
      ))}
    </div>
    <div class="horizon"></div>
  </section>


  <!-- 9 · BEYOND ACADEMIC -->
  <section class="bay">
    <div class="wide">
      <h2 class="lbl">Beyond academia</h2>
      <p class="dated-what" style="max-width:64ch">
        Trained as a stage actor with the Fudan Drama Troupe, and currently with the
        Windmill Chinese Drama Club in Chicago.
      </p>
      <p class="motto">{site.motto}</p>
      <p class="linkrow"><a href="/stage/">Stage →</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- 10 · CONTACT -->
  <section class="bay">
    <div class="wide">
      <h2 class="lbl">Contact</h2>
      <p class="dated-what"><a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></p>
      <p class="dated-what" style="color:var(--sea)">{site.closing}</p>
    </div>
    <div class="note">
      <p class="notesm">{site.contact.address.map((l) => <>{l}<br /></>)}</p>
    </div>
  </section>
</Base>

<style>
  .id-block { padding-top: var(--ma-4); }
  .statuslist { display: flex; flex-direction: column; gap: var(--ma-1); }
  .statuslist li {
    font-family: var(--mono); font-size: 12.5px; letter-spacing: .04em;
    text-transform: uppercase; color: var(--contour); line-height: 1.6;
  }
  .position { font-size: 17.5px; line-height: 1.5; margin: var(--ma-2) 0; max-width: 60ch; }
  .identity { font-style: italic; font-size: 19px; line-height: 1.45; color: var(--sea); margin: 0 0 var(--ma-3); max-width: 60ch; }
  .mail { font-family: var(--mono); font-size: 12px; color: var(--contour); margin: var(--ma-1) 0 var(--ma-3); }
  .bio { margin: 0; }
  .bio p { margin: 0 0 var(--ma-2); }
  .bio p:last-child { margin-bottom: 0; }
  .seal-inline { display: inline-block; width: 7px; height: 7px; background: var(--oxide); margin-right: 6px; vertical-align: 1px; }

  .tagnw { white-space: nowrap; }
  .portrait { width: 100%; max-width: 9.5rem; height: auto; border: 1px solid var(--kei); filter: grayscale(.12); }
  @media (max-width: 1000px) { .portrait { max-width: 8rem; } }

  .notesm { font-size: 13px; line-height: 1.55; color: var(--sea); margin: 0; }
  .subhead {
    font-family: var(--mono); font-size: 11px; letter-spacing: .1em;
    text-transform: uppercase; color: var(--sea); margin: calc(var(--ma-1) * -1) 0 0;
  }
  .undernote {
    font-size: 14px; line-height: 1.55; color: var(--sea);
    max-width: 64ch; margin: var(--ma-4) 0 0; padding-left: var(--ma-3);
    border-left: 1px solid var(--kei);
  }
  .prow { background-image: none; color: inherit; }
  .prow { text-decoration: none; }
  .prow:hover { background: var(--shoal); }
  .newsrow { grid-template-columns: 8.5rem minmax(0, 1fr); }
  .motto { font-style: normal; font-family: var(--mono); font-size: 11.5px; letter-spacing: .12em; text-transform: uppercase; color: var(--sea); margin: var(--ma-2) 0; }

  /* The lead award: emphasized but not a dark band. */
  .award-lead-row { padding-top: var(--ma-3); padding-bottom: var(--ma-3); align-items: baseline; }
  .award-headline { font-size: 20px; line-height: 1.3; color: var(--sumi); margin: 0; }
  .award-headline a { color: var(--sumi); }

  @media (max-width: 760px) { .newsrow { grid-template-columns: 7rem minmax(0, 1fr); } }
</style>
