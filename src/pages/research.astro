---
import Base from '../layouts/Base.astro';
import { site } from '../data/site.js';

/* Research experience, written by theme and goal — an insider reads the
   headline and knows what the work is, not just where it happened. */
const positions = [
  { when: '2023 —', theme: 'Cortical population dynamics and inter-areal computation', where: 'Doiron Lab · University of Chicago',
    goal: 'Extending balanced-network theory to nonlinear, population-wide correlated activity, and building a geometric and dynamical-systems account of how the activity of one cortical area shapes the computation performed in another — tested against simultaneous multi-area recordings.' },
  { when: '2024', theme: 'Retinal disinhibition and noise resilience', where: 'Wei Lab · University of Chicago',
    goal: 'Biologically plausible circuit models of retinal motifs, asking how distinct cell types collectively keep the retina’s output reliable across environments whose noise statistics differ by orders of magnitude.' },
  { when: '2021 — 2023', theme: 'Dynamic-network construction and sampling over joins', where: 'Nargesian group · University of Rochester',
    goal: 'Algorithms and data platforms for the exact, fast construction of dynamic networks from large time series; i.i.d. sampling over unions of joins; fairness-aware data integration.' },
  { when: '2021 — 2023', theme: 'Perceptual decision-making across the lifespan', where: 'Tadin Lab · University of Rochester',
    goal: 'How perceptual decisions unfold over time and change with age under varying perceptual noise, and the social effects of crowd gaze on visual search.' },
  { when: '2021 — 2023', theme: 'Stress neurobiology from imaging, via representation learning', where: 'CogT Lab · Stanford University',
    goal: 'Graph neural networks, dimensionality reduction and representation learning applied to human fMRI and mesoscopic calcium imaging of stress neurobiology.' },
  { when: '2020 — 2023', theme: 'Abstract-rule learning and visual decision confidence', where: 'CCNN Lab · Shanghai Jiao Tong University',
    goal: 'Semi-supervised learning for Raven’s Progressive Matrices, and computational models of visual decision-making and confidence in OCD from behavioural and fMRI data.' },
  { when: '2023', theme: 'Supervised training algorithms for spiking networks', where: 'Mathematics honors thesis · University of Rochester',
    goal: 'With Alex Iosevich — supervised methods for training spiking neural networks.' },
  { when: '2023', theme: 'Perception versus cognition, and machine experience', where: 'Philosophy · University of Rochester',
    goal: 'With Alison Peterman — the relationship between computational models of visual perception and visual phenomenal experience.' },
];
---

<Base title="Research" current="Research"
  description="Research statement: the mechanisms of perceptual and conscious experience in intelligent systems, approached through computational neuroscience, artificial intelligence, and AI for science.">

  <section class="bay">
    <div class="main rhead">
      <h1 class="wordmark">Research</h1>
      <p class="identity">My research aims to decipher the {site.identity}.</p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- Plain-language framing so the page doesn't read philosophy-first -->
  <section class="bay">
    <div class="rail"><span class="num">01</span></div>
    <div class="main prose">
      <p>{site.framing}</p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- THE THREE APPROACHES -->
  <section class="bay">
    <div class="main"><p class="lbl">Approaches</p></div>
  </section>
  <section class="bay">
    <div class="wide">
      <div class="triad">
        {site.approaches.map((a) => (<div><h3>{a.name}</h3><p>{a.line}</p></div>))}
      </div>
      <p class="undernote">{site.approachesNote}</p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- FULL STATEMENT -->
  <section class="bay fade">
    <div class="main"><p class="lbl">Statement</p></div>
  </section>
  <section class="bay fade">
    <div class="main">
      <div class="prose">{site.statement.map((p) => <p>{p}</p>)}</div>
      <p class="linkrow" style="margin-top:var(--ma-3)"><a href="/projects/">The six projects in detail →</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- RESEARCH EXPERIENCE — theme-led -->
  <section class="bay fade">
    <div class="main"><p class="lbl">Research experience</p></div>
  </section>
  <section class="bay fade">
    <div class="wide">
      {positions.map((p) => (
        <div class="dated exp">
          <div class="dated-when">{p.when}</div>
          <div>
            <p class="dated-what">{p.theme}</p>
            <p class="dated-detail">{p.goal}</p>
          </div>
          <div class="dated-where">{p.where}</div>
        </div>
      ))}
    </div>
    <div class="horizon"></div>
  </section>

  <!-- TEACHING -->
  <section class="bay fade">
    <div class="main"><p class="lbl">Teaching</p></div>
  </section>
  <section class="bay fade">
    <div class="wide">
      {site.teaching.map((t) => (
        <div class="dated">
          <div class="dated-when">{t.when}</div>
          <div><p class="dated-what">{t.what}</p></div>
          <div class="dated-where">{t.where}</div>
        </div>
      ))}
    </div>
    <div class="horizon"></div>
  </section>

  <!-- SERVICE -->
  <section class="bay fade">
    <div class="main"><p class="lbl">Service</p></div>
  </section>
  <section class="bay fade">
    <div class="wide">
      {site.service.map((s) => (
        <div class="dated">
          <div class="dated-when">{s.when}</div>
          <div>
            <p class="dated-what">{s.what}</p>
            {s.detail && <p class="dated-detail">{s.detail}</p>}
          </div>
          <div class="dated-where">{s.where}</div>
        </div>
      ))}
      <p class="lbl" style="margin:var(--ma-4) 0 var(--ma-2)">Reviewing</p>
      <p class="strip">{site.reviewing.join(' · ')}</p>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- COLLABORATORS -->
  <section class="bay fade">
    <div class="main"><p class="lbl">Collaborators</p></div>
  </section>
  <section class="bay fade">
    <div class="wide">
      <ul class="names">
        {site.collaborators.map((c) => (
          <li>
            {c.href ? <a href={c.href}>{c.name}</a> : <span>{c.name}</span>}
            <span class="inst">{c.where}{c.role ? ' · ' + c.role : ''}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>

<style>
  .rhead { padding-top: var(--ma-4); display: flex; flex-direction: column; gap: var(--ma-3); }
  .identity { font-style: italic; font-size: 19px; line-height: 1.45; color: var(--sea); margin: 0; max-width: 60ch; }
  .undernote {
    font-size: 14px; line-height: 1.55; color: var(--sea);
    max-width: 64ch; margin: var(--ma-4) 0 0; padding-left: var(--ma-3);
    border-left: 1px solid var(--kei);
  }
  .exp .dated-detail { max-width: 60ch; }
</style>
