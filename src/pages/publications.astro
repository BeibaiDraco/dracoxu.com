---
import Base from '../layouts/Base.astro';
import PubRow from '../components/PubRow.astro';
import { groups } from '../data/publications.js';
---

<Base title="Publications" current="Publications"
  description="Publications, preprints and conference abstracts by Draco (Yunlong) Xu.">

  <section class="bay">
    <div class="wide pubhead">
      <h1 class="wordmark">Publications</h1>
      <p class="linkrow"><a href="https://scholar.google.com/citations?user=HHSvQskAAAAJ">Google Scholar</a><span class="sl">/</span><a href="/cv.pdf">CV (PDF)</a></p>
    </div>
    <div class="horizon"></div>
  </section>

  {groups.map((g) => (
    <>
      <section class="bay">
        <div class="wide">
          <h2 class="lbl">{g.label} <span class="cnt">({g.items.length})</span></h2>
        </div>
      </section>
      <section class="bay">
        <div class="wide">
          {g.items.map((item) => <PubRow item={item} plate={g.plates} compact={!g.plates} />)}
        </div>
        <div class="horizon"></div>
      </section>
    </>
  ))}

  <section class="bay">
    <div class="wide">
      <p class="legend">
        * denotes equal contribution. Plates are generated visual indices keyed to the
        kind of work — a correlation matrix, a raster, a network — not figures reproduced
        from the papers.
      </p>
    </div>
  </section>
</Base>

<style>
  .pubhead { padding-top: var(--ma-4); display: flex; flex-direction: column; gap: var(--ma-3); }
  .cnt { color: var(--sea); }
  .legend {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .06em;
    line-height: 1.7;
    color: var(--sea);
    max-width: 76ch;
    margin: 0;
  }
</style>
