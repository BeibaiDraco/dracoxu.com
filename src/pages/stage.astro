---
import Base from '../layouts/Base.astro';
import { site } from '../data/site.js';

const record = [
  { when: '2023 —', what: 'Windmill Chinese Drama Club', where: 'Chicago',
    logo: '/logo-windmill.jpg', logoAlt: 'Windmill Chinese Drama Club emblem' },
  { when: '2018 — 2021', what: 'Professional actor training, Fudan Drama Troupe', where: 'Shanghai',
    logo: '/logo-fudan-drama.jpg', logoAlt: 'Fudan Drama Troupe emblem' },
];

const stills = [
  { src: '/stage-ensemble.jpg', alt: 'A tight cluster of actors seen from behind, gathered centre stage against a dark wall.' },
  { src: '/stage-duet.jpg', alt: 'Two actors in a scene — one seated, looking up at the other, who stands over him in red.' },
  { src: '/stage-reading.jpg', alt: 'Six actors in a line mid-scene, two of them reading from papers.' },
  { src: '/stage-cast.jpg', alt: 'The company gathered for a group photograph in the black-box theatre after a performance.' },
];
---

<Base title="Stage" current="Stage"
  description="Stage acting — the Fudan Drama Troupe and the Windmill Chinese Drama Club in Chicago. The threshold studied in cortex, worked from the other side.">
  <section class="bay">
    <div class="wide stage-head">
      <span class="seal" aria-hidden="true"></span>
      <h1 class="wordmark stage-title">Stage</h1>
    </div>
    <div class="horizon"></div>
  </section>

  <!-- THE CLAIM — the through-line, not an apology for a hobby. -->
  <section class="bay fade">
    <div class="rail"><span class="num">01</span></div>
    <div class="main prose">
      <p>
        The thing I study in cortex is a threshold: the instant a signal stops being a signal and
        becomes something experienced. An actor works the same object from the other side — the
        beat before a line lands, when the room has not yet decided what it heard.
      </p>
      <p>
        I trained as an actor at the Fudan Drama Troupe and perform with the Windmill Chinese
        Drama Club in Chicago. Four words on the wall of that work, and of this site:
      </p>
    </div>
    <div class="note">
      <p class="lbl" style="margin-bottom:var(--ma-2)">A word with three readings</p>
      <ul class="readings">
        <li>the stage one acts on</li>
        <li>a stage of a process</li>
        <li>the platform a thing is shown on</li>
      </ul>
    </div>
  </section>

  <div class="bay">
    <div class="monolith">
      <p class="inner">{site.motto}</p>
    </div>
  </div>

  <!-- THE RECORD -->
  <section class="bay fade">
    <div class="rail"><span class="num">02</span></div>
    <div class="wide"><h2 class="lbl">Record</h2></div>
  </section>
  <section class="bay fade">
    <div class="wide">
      {record.map((r) => (
        <div class="troupe">
          <img class="troupe-logo" src={r.logo} alt={r.logoAlt} width="64" height="64" loading="lazy" />
          <div>
            <p class="row-t">{r.what}</p>
            <p class="troupe-meta">{r.when} · {r.where}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="horizon"></div>
  </section>

  <!-- STILLS -->
  <section class="bay fade">
    <div class="rail"><span class="num">03</span></div>
    <div class="wide"><h2 class="lbl">Stills</h2></div>
  </section>
  <section class="bay fade">
    <div class="wide">
      <div class="stills">
        {stills.map((s) => (
          <figure class="still">
            <img src={s.src} alt={s.alt} loading="lazy" />
          </figure>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .stage-head { padding-top: var(--ma-4); display: flex; flex-direction: column; gap: var(--ma-4); }
  .stage-title { margin: 0; }
  .readings { display: flex; flex-direction: column; gap: var(--ma-2); }
  .readings li { font-size: 14px; color: var(--sea); line-height: 1.5; }

  .troupe {
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr);
    column-gap: var(--ma-4);
    align-items: center;
    padding: var(--ma-3) 0;
    border-bottom: 1px solid var(--kei);
  }
  .troupe-logo { width: 64px; height: 64px; object-fit: contain; }
  .troupe-meta {
    font-family: var(--mono); font-size: 11.5px; letter-spacing: .08em;
    text-transform: uppercase; color: var(--sea); margin: var(--ma-1) 0 0;
  }

  .stills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--ma-3);
  }
  .still { margin: 0; }
  .still img {
    width: 100%; aspect-ratio: 4 / 3; object-fit: cover;
    border: 1px solid var(--kei);
  }
</style>
